# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Telegram bot ──────────────────────────────────────────────
BOT_TOKEN=

# Telegram Stars price for a Pro subscription (integer, stars)
STARS_AMOUNT=300

# KRW price charged via Telegram invoice (integer, KRW)
SUBSCRIPTION_PRICE_KRW=9900

# Days of access granted for a Telegram Stars / KRW payment
SUBSCRIPTION_DAYS=30

# ── Admins & support group ────────────────────────────────────
# Comma-separated Telegram user IDs who can approve Toss payments
# and reply via the support relay. Falls back to ADMIN_TELEGRAM_ID (legacy).
ADMIN_TELEGRAM_IDS=

# Chat ID of the shared support super-group (negative number).
# Required for both the Toss approval UI and the support relay.
# Bot must be added to that group with privacy mode disabled in BotFather.
SUPPORT_CHAT_ID=

# ── Toss bank-transfer flow ───────────────────────────────────
# Toss flow is enabled only when SUPPORT_CHAT_ID, TOSS_ACCOUNT_NUMBER,
# and at least one ADMIN_TELEGRAM_IDS entry are all set.
TOSS_BANK_NAME=토스뱅크
TOSS_ACCOUNT_NUMBER=
TOSS_ACCOUNT_HOLDER=

# KRW amount the user must transfer via Toss (integer, KRW)
TOSS_PRICE_KRW=9900

# Days of access granted for an approved Toss transfer
TOSS_DAYS=30

# ── Telegram invoice provider (optional) ──────────────────────
# Leave empty to accept Telegram Stars only
PAYMENT_PROVIDER_TOKEN=
