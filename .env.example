# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Telegram bot ──────────────────────────────────────────────
BOT_TOKEN=

# Telegram Stars price for a Pro subscription (integer, stars)
STARS_AMOUNT=300

# KRW price charged via Telegram invoice (integer, KRW)
SUBSCRIPTION_PRICE_KRW=9900

# Days of access granted for a Telegram Stars / KRW payment
SUBSCRIPTION_DAYS=30

# ── Toss bank-transfer flow ───────────────────────────────────
# Leave ADMIN_TELEGRAM_ID or TOSS_ACCOUNT_NUMBER blank to disable Toss
ADMIN_TELEGRAM_ID=
TOSS_BANK_NAME=토스뱅크
TOSS_ACCOUNT_NUMBER=
TOSS_ACCOUNT_HOLDER=

# KRW amount the user must transfer via Toss (integer, KRW)
TOSS_PRICE_KRW=9900

# Days of access granted for an approved Toss transfer
TOSS_DAYS=30

# ── Telegram invoice provider (optional) ──────────────────────
# Leave empty to accept Telegram Stars only
PAYMENT_PROVIDER_TOKEN=
